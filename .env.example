# Источник каталога (переопределяет site.config.ts при необходимости)
CATALOG_URL=
CATALOG_SOURCE=

# Пайплайн: sync → enrich → fetch-model → embed → build

# GigaChat — только на сборке (Authorization key в Base64)
GIGACHAT_AUTH_KEY=
# Альias (legacy): GIGACHAT_API_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
# На Windows при ошибке TLS: GIGACHAT_TLS_INSECURE=1

# Релей заказов (клиент, попадает в бандл)
PUBLIC_ORDER_RELAY_URL=http://localhost:8787

# --- переменные релая (relay/, Yandex Cloud Function, build-only) ---
TELEGRAM_BOT_TOKEN=
# JSON: {"demo":{"name":"...","email":"...","telegramChatId":"..."}}
TENANTS_JSON=
DEMO_ORDER_EMAIL=
DEMO_TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CORS_ORIGIN=*
# Локальная проверка без Telegram/SMTP: RELAY_DRY_RUN=1
RELAY_DRY_RUN=

# Telegram chat id тенанта (для справки, в site.config.ts)
TELEGRAM_CHAT_ID=
