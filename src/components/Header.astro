---
import { getCategories } from '../lib/catalog';
import siteConfig from '../../site.config';

const categories = getCategories();
---

<div class="topbar">
  <div class="container topbar__inner">
    <div class="topbar__links">
      <a href="/catalog/">Каталог</a>
      <a href="/showroom/">Салоны</a>
      <a href="/delivery/">Доставка и оплата</a>
      <a href="/services/">Услуги</a>
    </div>
    <div class="topbar__contacts">
      <span class="topbar__city">{siteConfig.contacts.city}</span>
      <a class="topbar__phone" href={`tel:${siteConfig.contacts.phone.replace(/\D/g, '')}`}>
        {siteConfig.contacts.phone}
      </a>
    </div>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo">{siteConfig.name}</a>

    <nav class="site-header__nav" aria-label="Основная навигация">
      <details class="catalog-menu">
        <summary class="catalog-menu__trigger">Каталог</summary>
        <div class="catalog-menu__panel">
          <div class="catalog-menu__grid">
            {categories.length > 0 ? (
              categories.map((cat) => (
                <a href={`/catalog/?category=${encodeURIComponent(cat.id)}`} class="catalog-menu__link">
                  <span class="catalog-menu__label">{cat.label}</span>
                  <span class="catalog-menu__count text-muted">{cat.count}</span>
                </a>
              ))
            ) : (
              <a href="/catalog/" class="catalog-menu__link">Весь каталог</a>
            )}
          </div>
          <a href="/catalog/" class="catalog-menu__all">Смотреть весь каталог</a>
        </div>
      </details>
    </nav>

    <form class="site-header__search" action="/search/" method="get" role="search" data-header-search>
      <label class="visually-hidden" for="header-search">Поиск по каталогу</label>
      <div class="site-header__search-pill">
        <svg class="site-header__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"></circle>
          <path d="M20 20l-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
        <input
          id="header-search"
          type="search"
          name="q"
          placeholder="Найти мебель по описанию"
          autocomplete="off"
          required
        />
        <a href="/#photo-search" class="site-header__camera" aria-label="Поиск по фото">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M4 7h3l2-2h6l2 2h3a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Z"
              stroke="currentColor"
              stroke-width="1.5"></path>
            <circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="1.5"></circle>
          </svg>
        </a>
      </div>
    </form>

    <div class="site-header__meta">
      <a class="site-header__showroom text-muted" href={`tel:${siteConfig.contacts.phone.replace(/\D/g, '')}`}>
        <span class="site-header__city">{siteConfig.contacts.city}</span>
        <span class="site-header__phone">{siteConfig.contacts.phone}</span>
      </a>
      <a href="/cart/" class="site-header__cart" aria-label="Корзина">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M6 6h15l-1.5 9h-12L6 6Z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"></path>
          <path d="M6 6 5 3H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
          ></path>
          <circle cx="9" cy="19" r="1.5" fill="currentColor"></circle>
          <circle cx="18" cy="19" r="1.5" fill="currentColor"></circle>
        </svg>
        <span class="site-header__cart-count" data-cart-count hidden>0</span>
      </a>
    </div>
  </div>
</header>

<script>
  import { initCartBadge } from '../scripts/cart-ui';
  import { initHeaderSearch } from '../scripts/search-ui';

  initCartBadge();
  initHeaderSearch();
</script>
