---
import StoreLayout from '../../layouts/StoreLayout.astro';
import { buildSitePageSeo } from '../../lib/seo';
import siteConfig from '../../../site.config';

const seo = buildSitePageSeo(
  'Услуги',
  'Замер, сборка, дизайн-проект и комплектация интерьера',
  '/services/',
);
---

<StoreLayout title={seo.title} description={seo.description} canonicalUrl={seo.canonicalUrl}>
  <div class="container info-page">
    <h1>Услуги</h1>
    <p class="info-page__lead text-muted">
      Поможем подобрать мебель под ваш интерьер — от одного предмета до полной комплектации
      гостиной или спальни.
    </p>

    <div class="info-cards">
      <article class="info-card">
        <h2>Замер и планировка</h2>
        <p>
          Выезд замерщика в {siteConfig.contacts.city}, схема расстановки и рекомендации по
          размерам. Бесплатно при заказе от 50 000 ₽.
        </p>
      </article>

      <article class="info-card">
        <h2>Сборка и установка</h2>
        <p>
          Сборка корпусной мебели, крепление к стене, регулировка фасадов. Гарантия на работы —
          12 месяцев.
        </p>
      </article>

      <article class="info-card">
        <h2>Комплекты под ключ</h2>
        <p>
          Готовые решения для гостиной, спальни и кабинета — согласуем состав, цвет и срок
          поставки одним заказом.
        </p>
      </article>

      <article class="info-card">
        <h2>Поиск по фото</h2>
        <p>
          Нашли понравившуюся мебель в интернете? Загрузите фото на главной странице — подберём
          похожие модели из нашего каталога.
        </p>
        <a href="/#photo-search" class="info-card__link">Попробовать поиск по фото</a>
      </article>
    </div>

    <p class="info-page__cta">
      Записаться на консультацию:
      <a href={`mailto:${siteConfig.contacts.email}`}>{siteConfig.contacts.email}</a>
    </p>
  </div>
</StoreLayout>

<style>
  .info-page {
    padding: calc(var(--space) * 8) 0 calc(var(--space) * 12);
  }

  .info-page__lead {
    font-size: 1.125rem;
    margin: calc(var(--space) * 3) 0 calc(var(--space) * 8);
    max-width: 640px;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: calc(var(--space) * 5);
    margin-bottom: calc(var(--space) * 8);
  }

  .info-card {
    padding: calc(var(--space) * 5);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
  }

  .info-card h2 {
    font-size: 1.125rem;
    margin-bottom: calc(var(--space) * 3);
  }

  .info-card p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.9375rem;
  }

  .info-card__link {
    display: inline-block;
    margin-top: calc(var(--space) * 3);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .info-page__cta {
    padding: calc(var(--space) * 5);
    background: var(--surface-2);
    border-radius: var(--radius-card);
    max-width: 640px;
  }

  @media (max-width: 768px) {
    .info-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
