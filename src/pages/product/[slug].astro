---
import AvailabilityBadge from '../../components/AvailabilityBadge.astro';
import PriceBlock from '../../components/PriceBlock.astro';
import ServicesBlock from '../../components/ServicesBlock.astro';
import ShowroomAddress from '../../components/ShowroomAddress.astro';
import SimilarProducts from '../../components/SimilarProducts.astro';
import StoreLayout from '../../layouts/StoreLayout.astro';
import { getCapabilities, getProducts } from '../../lib/catalog';
import {
  attributeLabel,
  formatAttributeValue,
  productImageAlt,
} from '../../lib/format';
import {
  buildProductPageSeo,
  productDescription,
  splitRichText,
} from '../../lib/seo';
import { deriveVariantAxes, getColorHex } from '../../lib/variants';
import type { Product } from '../../lib/types/product';

export function getStaticPaths() {
  return getProducts().map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const capabilities = getCapabilities();
const mainImage = product.images[0];
const variantConfig = deriveVariantAxes(product);
const hasVariants = Boolean(variantConfig);
const descriptionParagraphs = splitRichText(productDescription(product));
const seo = buildProductPageSeo(product);

const colorImageMap = variantConfig?.colorImage ?? {};
const thumbColorBySrc = new Map<string, string>(
  Object.entries(colorImageMap).map(([color, src]) => [src, color]),
);
---

<StoreLayout
  title={seo.title}
  description={seo.description}
  canonicalUrl={seo.canonicalUrl}
  ogType={seo.ogType}
  ogImage={seo.ogImage}
  jsonLd={seo.jsonLd}
>
  <article class="pdp container" data-product-page>
    <div class="pdp__gallery">
      {product.images.length > 0 ? (
        <div class="pdp__images">
          <img
            class="pdp__main-image"
            data-product-main-image
            src={mainImage}
            alt={productImageAlt(product)}
            width="640"
            height="480"
          />
          {product.images.length > 1 && (
            <div class="pdp__thumbs" role="list" aria-label="Миниатюры">
              {product.images.map((img, i) => {
                const thumbColor = thumbColorBySrc.get(img);
                return (
                  <button
                    type="button"
                    class:list={['pdp__thumb', { 'is-active': i === 0 }]}
                    data-thumb-src={img}
                    data-color={thumbColor ?? undefined}
                    aria-label={
                      thumbColor
                        ? `Цвет: ${thumbColor}`
                        : `Показать фото ${i + 1}`
                    }
                    aria-pressed={i === 0 ? 'true' : 'false'}
                  >
                    <img src={img} alt="" width="72" height="72" loading="lazy" />
                  </button>
                );
              })}
            </div>
          )}
        </div>
      ) : (
        <div class="pdp__placeholder" role="img" aria-label="Нет фото">
          <span class="text-muted">Нет фото</span>
        </div>
      )}
    </div>

    <div class="pdp__info">
      <AvailabilityBadge product={product} />

      <h1>{product.title}</h1>

      <PriceBlock price={product.price} oldPrice={product.oldPrice} class="pdp__price" />

      <p class="pdp__showroom text-muted">
        Шоурум: <ShowroomAddress />
      </p>

      {hasVariants && variantConfig && (
        <div class="pdp__variants" data-product-variants>
          {variantConfig.axes.map((axis) => (
            <div class="pdp__axis" data-axis-group={axis.key}>
              <p class="pdp__axis-label">{axis.label}</p>
              <div
                class="pdp__axis-options"
                role="group"
                aria-label={axis.label}
              >
                {axis.values.map((value, i) => {
                  const isActive = variantConfig.defaultSelection[axis.key] === value;
                  const hex = axis.isColor ? getColorHex(value) : undefined;

                  return axis.isColor ? (
                    <button
                      type="button"
                      class:list={['color-swatch', { 'is-active': isActive }]}
                      data-axis={axis.key}
                      data-value={value}
                      aria-label={value}
                      aria-pressed={isActive ? 'true' : 'false'}
                      title={value}
                    >
                      {hex ? (
                        <span class="color-swatch__chip" style={`background:${hex}`} />
                      ) : (
                        <span class="color-swatch__text">{value}</span>
                      )}
                    </button>
                  ) : (
                    <button
                      type="button"
                      class:list={['variant-btn', { 'is-active': isActive }]}
                      data-axis={axis.key}
                      data-value={value}
                      aria-pressed={isActive ? 'true' : 'false'}
                    >
                      {axis.key === 'width_cm' ? `${value} см` : value}
                    </button>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      )}

      <button
        type="button"
        class="btn btn--primary btn--lg pdp__add"
        data-add-to-cart
        data-product-id={product.id}
        data-slug={product.slug}
        data-title={product.title}
        data-base-title={product.title}
        data-price={product.price}
        data-image={mainImage ?? ''}
        data-variant-id={hasVariants ? variantConfig!.variants[0].id : ''}
      >
        В корзину
      </button>

      <ServicesBlock />

      {descriptionParagraphs.length > 0 && (
        <section class="pdp__description">
          <h2>Описание</h2>
          {descriptionParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </section>
      )}

      {capabilities.attributes && Object.keys(product.attributes).length > 0 && (
        <section class="pdp__specs">
          <h2>Характеристики</h2>
          <dl class="spec-list">
            {Object.entries(product.attributes).map(([key, value]) => (
              <>
                <dt>{attributeLabel(key)}</dt>
                <dd data-spec-key={key}>{formatAttributeValue(value)}</dd>
              </>
            ))}
          </dl>
        </section>
      )}
    </div>
  </article>

  {hasVariants && variantConfig && (
    <script
      type="application/json"
      data-variant-config
      set:html={JSON.stringify({
        axes: variantConfig.axes.map(({ key, label, values, isColor }) => ({
          key,
          label,
          values,
          isColor,
        })),
        colorImage: variantConfig.colorImage,
        defaultSelection: variantConfig.defaultSelection,
        variants: variantConfig.variants,
        basePrice: variantConfig.basePrice,
      })}
    />
  )}

  <div class="container">
    <SimilarProducts productId={product.id} />
  </div>
</StoreLayout>

<script>
  import { initGalleryThumbs, initProductVariants } from '../../scripts/cart-ui';

  initGalleryThumbs();
  initProductVariants();
</script>

<style>
  .pdp {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--space) * 10);
    padding: calc(var(--space) * 8) 0 calc(var(--space) * 12);
  }

  .pdp__main-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-card);
    background: var(--surface-2);
  }

  .pdp__thumbs {
    display: flex;
    gap: calc(var(--space) * 2);
    margin-top: calc(var(--space) * 3);
    overflow-x: auto;
  }

  .pdp__thumb {
    flex: 0 0 auto;
    padding: 0;
    border: 2px solid transparent;
    border-radius: calc(var(--radius-control) / 2);
    background: none;
    cursor: pointer;
    overflow: hidden;
  }

  .pdp__thumb.is-active {
    border-color: var(--accent);
  }

  .pdp__thumb:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .pdp__thumb img {
    display: block;
    width: 72px;
    height: 72px;
    object-fit: cover;
  }

  .pdp__placeholder {
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    background: var(--surface-2);
    border-radius: var(--radius-card);
  }

  .pdp__info h1 {
    margin-top: calc(var(--space) * 3);
  }

  .pdp__showroom {
    margin: calc(var(--space) * 3) 0 0;
    font-size: 0.875rem;
  }

  .pdp__variants {
    margin: calc(var(--space) * 6) 0;
    display: flex;
    flex-direction: column;
    gap: calc(var(--space) * 5);
  }

  .pdp__axis-label {
    font-weight: 500;
    margin-bottom: calc(var(--space) * 3);
  }

  .pdp__axis-options {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--space) * 2);
  }

  .variant-btn {
    padding: calc(var(--space) * 2) calc(var(--space) * 4);
    border: 1px solid var(--line);
    border-radius: var(--radius-control);
    background: var(--surface);
    font: inherit;
    cursor: pointer;
  }

  .variant-btn.is-active {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--surface));
  }

  .variant-btn:focus-visible,
  .color-swatch:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .color-swatch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 2px;
    border: 2px solid var(--line);
    border-radius: 50%;
    background: var(--surface);
    cursor: pointer;
  }

  .color-swatch.is-active {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .color-swatch__chip {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }

  .color-swatch__text {
    font-size: 0.625rem;
    line-height: 1;
    text-align: center;
    padding: 0 2px;
  }

  .pdp__add {
    width: 100%;
    max-width: 20rem;
  }

  .pdp__description,
  .pdp__specs {
    margin-top: calc(var(--space) * 8);
  }

  .pdp__description h2,
  .pdp__specs h2 {
    font-size: 1.25rem;
    margin-bottom: calc(var(--space) * 4);
  }

  .pdp__description p:last-child {
    margin-bottom: 0;
  }

  .spec-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--space) * 2) calc(var(--space) * 4);
    margin: 0;
  }

  .spec-list dt {
    color: var(--ink-muted);
    font-size: 0.875rem;
  }

  .spec-list dd {
    margin: 0;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .pdp {
      grid-template-columns: 1fr;
      gap: calc(var(--space) * 6);
    }

    .spec-list {
      grid-template-columns: 1fr;
    }
  }
</style>
