---
import InfoLayout from '../../layouts/InfoLayout.astro';
import siteConfig from '../../../site.config';

const faqItems = [
  {
    q: 'Как оформить заказ?',
    a: 'Добавьте товары в корзину и нажмите «Оформить заказ». Укажите имя, телефон и адрес доставки. Менеджер свяжется для подтверждения.',
  },
  {
    q: 'Сколько ждать доставку?',
    a: 'По Москве — обычно 3–14 рабочих дней. Точный срок зависит от наличия и модели, сообщим после оформления.',
  },
  {
    q: 'Можно ли оплатить при получении?',
    a: 'Да — наличными или картой курьеру. Для юридических лиц доступен безналичный расчёт по счёту.',
  },
  {
    q: 'Как работает поиск по фото?',
    a: 'На главной странице загрузите фото мебели — система подберёт похожие модели из каталога. Фото обрабатывается на сервере магазина и не сохраняется.',
  },
  {
    q: 'Можно ли вернуть товар?',
    a: 'Да, в течение 7 дней — если сохранён товарный вид и упаковка. Подробнее на странице «Возврат и обмен».',
  },
  {
    q: 'Есть ли сборка?',
    a: 'Да. Сборка корпусной мебели и кроватей — от 1 500 ₽ за изделие. Диваны чаще поставляются собранными.',
  },
  {
    q: 'Где посмотреть мебель вживую?',
    a: `В наших салонах в ${siteConfig.contacts.city}. Адреса и карта — на странице «Салоны».`,
  },
];
---

<InfoLayout
  title="Вопросы и ответы"
  description="Частые вопросы о заказе, доставке, оплате и возврате мебели"
  path="/faq/"
  lead="Ответы на типичные вопросы. Не нашли нужное — напишите или позвоните нам."
>
  <div class="faq-list">
    {faqItems.map((item) => (
      <details class="faq-item">
        <summary>{item.q}</summary>
        <div class="faq-item__body">{item.a}</div>
      </details>
    ))}
  </div>

  <p class="info-page__cta">
    Остались вопросы:
    <a href={`tel:${siteConfig.contacts.phone.replace(/\D/g, '')}`}>{siteConfig.contacts.phone}</a>
    {' · '}
    <a href={`mailto:${siteConfig.contacts.email}`}>{siteConfig.contacts.email}</a>
  </p>
</InfoLayout>
